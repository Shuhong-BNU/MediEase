# Qwen / DashScope API key
# 通义千问 / DashScope 的 API 密钥，用来让程序有权限调用云端模型服务
QWEN_API_KEY="sk-292aa0ade48f438dacd61f269fcc2d15"

# Text or multimodal model
# 主问答模型；这里使用的是 Qwen 的多模态模型，可处理文本，也可处理图片
QWEN_MODEL="qwen-vl-plus-latest"

# Speech synthesis
# 语音合成（TTS）模型，用于把最终文本答案转换成语音
QWEN_TTS_MODEL="cosyvoice-v3-flash"

# 默认语音音色 / 发音人
# 决定系统播报答案时使用哪一种声音
QWEN_TTS_VOICE="longanyang"

# Embedding for memory vector retrieval
# 用于记忆向量检索的 embedding 模型，把文本转成向量，供相似度搜索使用
QWEN_EMBEDDING_MODEL="text-embedding-v4"

# Embedding 向量维度
# 表示每段文本会被编码成 1024 维的向量；要和向量库索引维度保持一致
QWEN_EMBEDDING_DIMENSIONS="1024"